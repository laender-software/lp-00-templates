---
import type { Persona } from "../../data/types";
import Icon from "../ui/Icon.astro";

interface Props {
  diferenciais: Persona["sections"]["diferenciais"];
  variant?: "icon-left" | "centered" | "checkmark" | "numbered" | "border-left" | "split-photo";
  photo?: string;
  bgColor?: "alt" | "default";
}

const { diferenciais, variant = "icon-left", bgColor = "default", photo } = Astro.props;
const bg = bgColor === "alt" ? "bg-[var(--color-bg-alt)]" : "bg-[var(--color-bg)]";
---

<section class:list={["py-20 md:py-28", bg]} id="diferenciais">
  <div class="mx-auto px-6 max-w-4xl text-center mb-12">
    <p class="text-[var(--color-accent)] text-sm font-semibold uppercase tracking-widest mb-4">Diferenciais</p>
    <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-semibold text-[var(--color-text-heading)]">{diferenciais.sectionTitle}</h2>
  </div>

  {/* ===== ICON-LEFT (Premium — horizontal com ícone) ===== */}
  {variant === "icon-left" && (
    <div class="mx-auto px-6 max-w-6xl grid sm:grid-cols-2 gap-6 stagger">
      {diferenciais.items.map((item) => (
        <div class="flex gap-4 p-6 bg-[var(--color-surface)] border border-[var(--color-border)] card-lift" style="border-radius: var(--radius-lg)">
          <Icon name={item.icon} class="w-6 h-6 text-[var(--color-accent)] mt-0.5 shrink-0" />
          <div>
            <h3 class="font-semibold text-[var(--color-text-heading)] mb-1">{item.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  )}

  {/* ===== CHECKMARK (Clean — lista simples com checks) ===== */}
  {variant === "checkmark" && (
    <div class="mx-auto px-6 max-w-3xl">
      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-6 stagger">
        {diferenciais.items.map((item) => (
          <div class="flex gap-3">
            <div class="w-5 h-5 shrink-0 mt-0.5 flex items-center justify-center bg-[var(--color-accent)]/15 text-[var(--color-accent)]" style="border-radius: var(--radius-full)">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-[var(--color-text-heading)] mb-0.5">{item.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* ===== CENTERED (Acolhedor — ícone centralizado empilhado) ===== */}
  {variant === "centered" && (
    <div class="mx-auto px-6 max-w-6xl grid sm:grid-cols-2 lg:grid-cols-4 gap-8 stagger">
      {diferenciais.items.map((item) => (
        <div class="text-center card-lift">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center bg-[var(--color-accent)]/10" style="border-radius: var(--radius-full)">
            <Icon name={item.icon} class="w-6 h-6 text-[var(--color-accent)]" />
          </div>
          <h3 class="font-semibold text-[var(--color-text-heading)] mb-2">{item.title}</h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  )}

  {/* ===== BORDER-LEFT (borda lateral colorida) ===== */}
  {variant === "border-left" && (
    <div class="mx-auto px-6 max-w-6xl grid sm:grid-cols-2 gap-5 stagger">
      {diferenciais.items.map((item) => (
        <div class="flex items-start gap-4 p-5 border-l-2 border-[var(--color-accent)] bg-[var(--color-surface)]/50 card-lift" style="border-radius: var(--radius-lg)">
          <Icon name={item.icon} class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" />
          <div>
            <h3 class="font-semibold text-[var(--color-text-heading)] mb-1">{item.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  )}

  {/* ===== SPLIT-PHOTO (Institucional — lista esquerda + foto direita) ===== */}
  {variant === "split-photo" && (
    <div class="mx-auto px-6 max-w-6xl grid md:grid-cols-2 gap-12 items-center">
      {/* Left: differentials list */}
      <div class="space-y-6 stagger">
        {diferenciais.items.map((item) => (
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 shrink-0 flex items-center justify-center bg-[var(--color-accent)]/10" style="border-radius: var(--radius-full)">
              <Icon name={item.icon} class="w-5 h-5 text-[var(--color-accent)]" />
            </div>
            <div>
              <h3 class="font-semibold text-[var(--color-text-heading)] mb-1">{item.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      {/* Right: clinic photo */}
      {photo && (
        <div class="relative overflow-hidden reveal" style="border-radius: var(--radius-lg)">
          <img
            src={photo}
            alt="Estrutura da clínica"
            class="w-full h-full object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
      )}
    </div>
  )}

  {/* ===== NUMBERED (Moderno — número grande + título) ===== */}
  {variant === "numbered" && (
    <div class="mx-auto px-6 max-w-6xl grid sm:grid-cols-2 gap-6 stagger">
      {diferenciais.items.map((item, i) => (
        <div class="flex gap-5 p-6">
          <span class="font-[var(--font-heading)] text-4xl font-bold text-[var(--color-accent)]/30 shrink-0 leading-none">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div>
            <h3 class="font-semibold text-[var(--color-text-heading)] mb-1">{item.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  )}
</section>
