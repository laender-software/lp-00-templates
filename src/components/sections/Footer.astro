---
import type { Persona } from "../../data/types";

interface Props {
  footer: Persona["sections"]["footer"];
  doctor: Persona["doctor"];
  instagram?: string;
  email?: string;
  variant?: "minimal" | "split" | "columns";
}

const { footer, doctor, instagram, email, variant = "minimal" } = Astro.props;
const year = new Date().getFullYear();
---

{/* ===== MINIMAL (default — compact, primary bg) ===== */}
{variant === "minimal" && (
  <footer class="py-12 bg-[var(--color-primary)] text-[var(--color-muted)]">
    <div class="mx-auto px-6 max-w-6xl">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="font-[var(--font-heading)] text-lg text-white font-semibold mb-1">{doctor.displayName}</p>
          <p class="text-sm">{doctor.crm}</p>
          <p class="text-sm">{doctor.address}</p>
        </div>
        <div class="flex items-center gap-6 text-sm">
          {instagram && (
            <a href={`https://instagram.com/${instagram.replace("@", "")}`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Instagram</a>
          )}
          {email && (
            <a href={`mailto:${email}`} class="hover:text-white transition-colors">{email}</a>
          )}
        </div>
      </div>
      <div class="border-t border-white/10 mt-8 pt-8 text-center text-xs">
        <p>{footer.copyright}</p>
        <p class="mt-1">&copy; {year} &mdash; Todos os direitos reservados</p>
      </div>
    </div>
  </footer>
)}

{/* ===== SPLIT (Acolhedor/Moderno — info esquerda, social/contato direita) ===== */}
{variant === "split" && (
  <footer class="py-16 bg-[var(--color-primary)] text-white/70">
    <div class="mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
        <div>
          <p class="font-[var(--font-heading)] text-xl text-white font-semibold mb-3">{doctor.displayName}</p>
          <p class="text-sm mb-1">{doctor.crm}</p>
          <p class="text-sm">{doctor.address}</p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2 text-sm">
            {instagram && (
              <a href={`https://instagram.com/${instagram.replace("@", "")}`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
                {instagram}
              </a>
            )}
            {email && (
              <a href={`mailto:${email}`} class="hover:text-white transition-colors flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {email}
              </a>
            )}
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 mt-12 pt-8 text-center text-xs">
        <p>{footer.copyright}</p>
        <p class="mt-1">&copy; {year} &mdash; Todos os direitos reservados</p>
      </div>
    </div>
  </footer>
)}

{/* ===== COLUMNS (Institucional — grid multi-coluna estruturado) ===== */}
{variant === "columns" && (
  <footer class="py-16 bg-[var(--color-primary)] text-[var(--color-muted)]">
    <div class="mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
        {/* Coluna 1 — Médico/Clínica */}
        <div>
          <p class="font-[var(--font-heading)] text-base text-white font-semibold mb-4">{doctor.displayName}</p>
          <p class="text-sm leading-relaxed mb-1">{doctor.crm}</p>
          <p class="text-sm leading-relaxed">{doctor.address}</p>
        </div>

        {/* Coluna 2 — Links rápidos */}
        <div>
          <p class="text-xs uppercase tracking-widest text-white/40 font-semibold mb-4">Navegação</p>
          <ul class="flex flex-col gap-2 text-sm">
            {(footer as any).links && Array.isArray((footer as any).links) ? (
              (footer as any).links.map((link: { text: string; href: string }) => (
                <li>
                  <a href={link.href} class="hover:text-white transition-colors">{link.text}</a>
                </li>
              ))
            ) : (
              <>
                <li><a href="#sobre" class="hover:text-white transition-colors">Sobre</a></li>
                <li><a href="#especialidades" class="hover:text-white transition-colors">Especialidades</a></li>
                <li><a href="#depoimentos" class="hover:text-white transition-colors">Depoimentos</a></li>
                <li><a href="#faq" class="hover:text-white transition-colors">Perguntas Frequentes</a></li>
              </>
            )}
          </ul>
        </div>

        {/* Coluna 3 — Contato */}
        <div>
          <p class="text-xs uppercase tracking-widest text-white/40 font-semibold mb-4">Contato</p>
          <ul class="flex flex-col gap-2 text-sm">
            {email && (
              <li>
                <a href={`mailto:${email}`} class="hover:text-white transition-colors">{email}</a>
              </li>
            )}
            <li class="leading-relaxed">{doctor.address}</li>
          </ul>
        </div>

        {/* Coluna 4 — Social */}
        <div>
          <p class="text-xs uppercase tracking-widest text-white/40 font-semibold mb-4">Redes Sociais</p>
          <div class="flex flex-col gap-2 text-sm">
            {instagram && (
              <a href={`https://instagram.com/${instagram.replace("@", "")}`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Instagram</a>
            )}
          </div>
        </div>
      </div>

      <div class="border-t border-white/10 mt-12 pt-8 text-center text-xs">
        <p>{footer.copyright}</p>
        <p class="mt-1">&copy; {year} &mdash; Todos os direitos reservados</p>
      </div>
    </div>
  </footer>
)}
