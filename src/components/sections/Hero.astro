---
import type { Persona } from "../../data/types";

interface Props {
  hero: Persona["sections"]["hero"];
  photo?: string;
  whatsapp: string;
  variant?: "split" | "centered" | "fullimage" | "split-reverse" | "cinematic";
}

const { hero, photo, whatsapp, variant = "split" } = Astro.props;
const whatsappLink = whatsapp ? `https://wa.me/${whatsapp}` : "#";

const isSplit = variant === "split" || variant === "split-reverse";
const isReverse = variant === "split-reverse";

/** Parse stat value like "15+", "3.000+", "98%", "12" into counter-friendly parts */
function parseStat(value: string) {
  const clean = value.replace(/\./g, ""); // remove thousand separators
  const match = clean.match(/^([^\d]*)(\d+)(.*)$/);
  if (!match) return { prefix: "", number: 0, suffix: "", original: value };
  return { prefix: match[1], number: parseInt(match[2]), suffix: match[3], original: value };
}
---

{/* ===== SPLIT (default) & SPLIT-REVERSE ===== */}
{isSplit && (
  <section class="pt-28 pb-16 md:pt-36 md:pb-24 bg-[var(--color-bg)]" id="hero">
    <div class:list={[
      "mx-auto px-6 max-w-6xl grid md:grid-cols-2 gap-12 items-center",
      isReverse && "md:[direction:rtl] md:[&>*]:[direction:ltr]"
    ]}>
      <div class="reveal">
        <p class="text-[var(--color-accent)] font-[var(--font-body)] text-sm font-semibold uppercase tracking-widest mb-4">
          {hero.badge}
        </p>
        <h1 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-semibold text-[var(--color-text-heading)] leading-tight mb-6">
          {hero.headline}{" "}<em class="text-[var(--color-accent)] not-italic">{hero.highlightWord}</em>
        </h1>
        <p class="text-[var(--color-muted)] text-lg mb-8 leading-relaxed">
          {hero.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-glow bg-[var(--color-accent)] text-[var(--color-primary)] px-8 py-3.5 font-semibold text-sm text-center hover:opacity-90 transition-opacity"
            style="border-radius: var(--radius-full)"
          >
            {hero.ctaText}
          </a>
          {hero.secondaryCta && (
            <a
              href={hero.secondaryCta.href}
              class="border-2 border-[var(--color-border)] text-[var(--color-text)] px-8 py-3.5 font-semibold text-sm text-center hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
              style="border-radius: var(--radius-full)"
            >
              {hero.secondaryCta.text}
            </a>
          )}
        </div>
      </div>

      <div class="reveal flex justify-center">
        <div class="w-full max-w-md aspect-[3/4] bg-[var(--color-surface)] overflow-hidden photo-zoom" style="border-radius: var(--radius-lg)">
          <img src={photo} alt="Foto do médico" class="w-full h-full object-cover" loading="eager" />
        </div>
      </div>
    </div>

    {hero.stats && hero.stats.length > 0 && (
      <div class="mx-auto px-6 max-w-6xl mt-16">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] grid divide-x divide-[var(--color-border)]" style={`border-radius: var(--radius-lg); grid-template-columns: repeat(${hero.stats.length}, minmax(0, 1fr))`}>
          {hero.stats.map((stat) => (
            <div class="flex flex-col items-center py-6 px-4 reveal">
              <span class="font-[var(--font-heading)] text-3xl md:text-4xl font-semibold text-[var(--color-accent)]"
                data-counter={parseStat(stat.value).number}
                data-prefix={parseStat(stat.value).prefix}
                data-suffix={parseStat(stat.value).suffix}
              >
                {stat.value}
              </span>
              <span class="text-[var(--color-muted)] text-xs md:text-sm mt-1 text-center">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
)}

{/* ===== CENTERED ===== */}
{variant === "centered" && (
  <section class="pt-28 pb-16 md:pt-40 md:pb-24 bg-[var(--color-bg)]" id="hero">
    <div class="mx-auto px-6 max-w-3xl text-center reveal">
      <p class="text-[var(--color-accent)] font-[var(--font-body)] text-sm font-semibold uppercase tracking-widest mb-4">
        {hero.badge}
      </p>
      <h1 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-semibold text-[var(--color-text-heading)] leading-tight mb-6">
        {hero.headline}{" "}<em class="text-[var(--color-accent)] not-italic">{hero.highlightWord}</em>
      </h1>
      <p class="text-[var(--color-muted)] text-lg mb-8 leading-relaxed max-w-2xl mx-auto">
        {hero.subheadline}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-glow bg-[var(--color-accent)] text-white px-8 py-3.5 font-semibold text-sm text-center hover:opacity-90 transition-opacity"
          style="border-radius: var(--radius-full)"
        >
          {hero.ctaText}
        </a>
        {hero.secondaryCta && (
          <a
            href={hero.secondaryCta.href}
            class="border-2 border-[var(--color-border)] text-[var(--color-text)] px-8 py-3.5 font-semibold text-sm text-center hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
            style="border-radius: var(--radius-full)"
          >
            {hero.secondaryCta.text}
          </a>
        )}
      </div>
    </div>

    <div class="mx-auto px-6 max-w-4xl reveal">
      <div class="w-full aspect-[16/9] bg-[var(--color-surface)] overflow-hidden photo-zoom" style="border-radius: var(--radius-lg)">
        <img src={photo} alt="Foto do médico" class="w-full h-full object-cover object-top" loading="eager" />
      </div>
    </div>

    {hero.stats && hero.stats.length > 0 && (
      <div class="mx-auto px-6 max-w-4xl mt-12">
        <div class="grid gap-8" style={`grid-template-columns: repeat(${hero.stats.length}, minmax(0, 1fr))`}>
          {hero.stats.map((stat) => (
            <div class="text-center reveal">
              <span class="font-[var(--font-heading)] text-3xl md:text-4xl font-semibold text-[var(--color-accent)]"
                data-counter={parseStat(stat.value).number}
                data-prefix={parseStat(stat.value).prefix}
                data-suffix={parseStat(stat.value).suffix}
              >
                {stat.value}
              </span>
              <p class="text-[var(--color-muted)] text-sm mt-1">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
)}

{/* ===== FULLIMAGE ===== */}
{variant === "fullimage" && (
  <section class="relative min-h-[90svh] flex items-center bg-[var(--color-bg)]" id="hero">
    <div class="absolute inset-0 overflow-hidden photo-zoom">
      <img src={photo} alt="Foto do médico" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg)]/90 via-[var(--color-bg)]/60 to-transparent"></div>
    </div>

    <div class="relative z-10 mx-auto px-6 max-w-6xl w-full pt-28">
      <div class="max-w-xl">
        <p class="text-[var(--color-accent)] font-[var(--font-body)] text-sm font-semibold uppercase tracking-widest mb-4 reveal">
          {hero.badge}
        </p>
        <h1 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-semibold text-[var(--color-text-heading)] leading-tight mb-6 reveal">
          {hero.headline}{" "}<em class="text-[var(--color-accent)] not-italic">{hero.highlightWord}</em>
        </h1>
        <p class="text-[var(--color-text)] text-lg mb-8 leading-relaxed reveal">
          {hero.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 reveal">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-glow bg-[var(--color-accent)] text-white px-8 py-3.5 font-semibold text-sm text-center hover:opacity-90 transition-opacity"
            style="border-radius: var(--radius-full)"
          >
            {hero.ctaText}
          </a>
          {hero.secondaryCta && (
            <a
              href={hero.secondaryCta.href}
              class="border-2 border-white/30 text-[var(--color-text-heading)] px-8 py-3.5 font-semibold text-sm text-center hover:border-white/60 transition-colors backdrop-blur-sm"
              style="border-radius: var(--radius-full)"
            >
              {hero.secondaryCta.text}
            </a>
          )}
        </div>

        {hero.stats && hero.stats.length > 0 && (
          <div class="flex gap-8 mt-12 reveal">
            {hero.stats.map((stat) => (
              <div>
                <span class="font-[var(--font-heading)] text-3xl font-semibold text-[var(--color-accent)]">
                  {stat.value}
                </span>
                <p class="text-[var(--color-muted)] text-sm mt-1">{stat.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
)}

{/* ===== CINEMATIC (Institucional — dark immersive hero with floating photos) ===== */}
{variant === "cinematic" && (
  <section class="relative min-h-[85svh] flex items-center overflow-hidden" id="hero" style="background: #0F1D2F;">
    {/* Subtle grid lines */}
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-px h-full bg-white"></div>
      <div class="absolute top-0 left-1/2 w-px h-full bg-white"></div>
      <div class="absolute top-0 left-3/4 w-px h-full bg-white"></div>
      <div class="absolute top-1/3 left-0 w-full h-px bg-white"></div>
      <div class="absolute top-2/3 left-0 w-full h-px bg-white"></div>
    </div>

    {/* Floating photos — decorative clinic images */}
    <div class="pointer-events-none absolute inset-0 hidden md:block" aria-hidden="true">
      <div class="absolute bottom-24 left-8 w-28 h-20 bg-white/5 border border-white/10 overflow-hidden" style="border-radius: var(--radius-lg); transform: rotate(-3deg);">
        <img src="/images/institucional-recepcao.jpg" alt="" class="w-full h-full object-cover opacity-60" loading="eager" />
      </div>
      <div class="absolute top-24 right-12 w-32 h-24 bg-white/5 border border-white/10 overflow-hidden" style="border-radius: var(--radius-lg); transform: rotate(2deg);">
        <img src="/images/institucional-laboratorio.jpg" alt="" class="w-full h-full object-cover opacity-60" loading="eager" />
      </div>
      <div class="absolute bottom-32 right-24 w-24 h-20 bg-white/5 border border-white/10 overflow-hidden" style="border-radius: var(--radius-lg); transform: rotate(-1deg);">
        <img src="/images/institucional-consultorio.jpg" alt="" class="w-full h-full object-cover opacity-60" loading="eager" />
      </div>
    </div>

    {/* Content */}
    <div class="relative z-10 mx-auto px-6 max-w-3xl w-full text-center pt-28 pb-16 reveal">
      <p class="text-[var(--color-accent)] font-[var(--font-body)] text-sm font-semibold uppercase tracking-[0.2em] mb-6">
        {hero.badge}
      </p>
      <h1 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-semibold text-white leading-tight mb-6">
        {hero.headline}{" "}<em class="text-[var(--color-accent)] not-italic">{hero.highlightWord}</em>
      </h1>
      <p class="text-slate-400 text-lg mb-10 leading-relaxed max-w-2xl mx-auto">
        {hero.subheadline}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-glow bg-[var(--color-accent)] text-white px-8 py-3.5 font-semibold text-sm text-center hover:opacity-90 transition-opacity"
          style="border-radius: var(--radius-full)"
        >
          {hero.ctaText}
        </a>
        {hero.secondaryCta && (
          <a
            href={hero.secondaryCta.href}
            class="border border-white/20 text-white px-8 py-3.5 font-semibold text-sm text-center hover:border-white/40 transition-colors"
            style="border-radius: var(--radius-full)"
          >
            {hero.secondaryCta.text}
          </a>
        )}
      </div>
    </div>

    {/* Stats bar at bottom */}
    {hero.stats && hero.stats.length > 0 && (
      <div class="absolute bottom-0 left-0 right-0 border-t border-white/10">
        <div class="mx-auto max-w-4xl grid gap-0 divide-x divide-white/10" style={`grid-template-columns: repeat(${hero.stats.length}, minmax(0, 1fr))`}>
          {hero.stats.map((stat) => (
            <div class="text-center py-6 reveal">
              <span class="font-[var(--font-heading)] text-2xl md:text-3xl font-semibold text-white"
                data-counter={parseStat(stat.value).number}
                data-prefix={parseStat(stat.value).prefix}
                data-suffix={parseStat(stat.value).suffix}
              >
                {stat.value}
              </span>
              <p class="text-slate-500 text-xs mt-1 uppercase tracking-wider">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Scroll indicator */}
    <div class="absolute bottom-20 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-pulse">
      <span class="text-slate-500 text-[0.65rem] uppercase tracking-[0.2em]">Explorar</span>
      <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
    </div>
  </section>
)}
