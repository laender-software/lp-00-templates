---
import type { Persona } from "../../data/types";

interface Props {
  videos: NonNullable<Persona["sections"]["videos"]>;
  instagram?: string;
  variant?: "grid" | "scroll";
}

const { videos, instagram, variant = "grid" } = Astro.props;

const platformIcons: Record<string, { label: string; color: string }> = {
  instagram: { label: "Instagram", color: "#E4405F" },
  youtube: { label: "YouTube", color: "#FF0000" },
  tiktok: { label: "TikTok", color: "#000000" },
};
---

<section class="py-20 md:py-28 bg-[var(--color-bg-alt)]" id="videos">
  <div class="mx-auto px-6 max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-[var(--color-accent)] text-sm font-semibold uppercase tracking-widest mb-4">Conteúdo</p>
      <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-semibold text-[var(--color-text-heading)]">{videos.sectionTitle}</h2>
      {videos.sectionSubtitle && (
        <p class="text-[var(--color-muted)] mt-4 max-w-2xl mx-auto leading-relaxed">{videos.sectionSubtitle}</p>
      )}
    </div>

    {/* ===== GRID (default — 3 colunas de cards 9:16) ===== */}
    {variant === "grid" && (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {videos.items.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block overflow-hidden card-lift reveal"
            style="border-radius: var(--radius-lg)"
          >
            <div class="relative aspect-[9/16] bg-[var(--color-surface)] overflow-hidden">
              <img
                src={item.thumbnail}
                alt={item.title}
                class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105"
                loading="lazy"
              />
              {/* Gradient overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              {/* Platform badge */}
              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1.5 flex items-center gap-1.5 shadow-sm" style="border-radius: var(--radius-full)">
                <span class="w-2 h-2 rounded-full" style={`background: ${platformIcons[item.platform]?.color || '#666'}`}></span>
                <span class="text-xs font-semibold text-gray-700">{platformIcons[item.platform]?.label || item.platform}</span>
              </div>
              {/* Title overlay */}
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <p class="text-white text-sm font-semibold leading-snug">{item.title}</p>
              </div>
              {/* Play button */}
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="w-14 h-14 bg-white/90 rounded-full flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    {/* ===== SCROLL (horizontal scroll com snap) ===== */}
    {variant === "scroll" && (
      <div class="relative">
        <div class="videos-scroll flex gap-6 overflow-x-auto pb-4" style="scroll-snap-type: x mandatory">
          {videos.items.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block flex-shrink-0 w-[260px] md:w-[300px] overflow-hidden card-lift reveal"
              style="border-radius: var(--radius-lg); scroll-snap-align: start"
            >
              <div class="relative aspect-[9/16] bg-[var(--color-surface)] overflow-hidden">
                <img
                  src={item.thumbnail}
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1.5 flex items-center gap-1.5 shadow-sm" style="border-radius: var(--radius-full)">
                  <span class="w-2 h-2 rounded-full" style={`background: ${platformIcons[item.platform]?.color || '#666'}`}></span>
                  <span class="text-xs font-semibold text-gray-700">{platformIcons[item.platform]?.label || item.platform}</span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <p class="text-white text-sm font-semibold leading-snug">{item.title}</p>
                </div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="w-14 h-14 bg-white/90 rounded-full flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
        {/* Fade hint on the right */}
        <div class="hidden md:block absolute top-0 right-0 bottom-4 w-16 bg-gradient-to-l from-[var(--color-bg-alt)] to-transparent pointer-events-none"></div>
      </div>
    )}

    {/* Follow CTA */}
    {instagram && (
      <div class="text-center mt-10 reveal">
        <a
          href={`https://instagram.com/${instagram.replace("@", "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold text-sm hover:opacity-80 transition-opacity"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          Siga no Instagram
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .videos-scroll::-webkit-scrollbar { display: none; }
  .videos-scroll { -ms-overflow-style: none; scrollbar-width: none; }
</style>
