---
const styles = [
  { name: "Premium", href: "/premium/", description: "Luxo, escuro, autoridade", status: "ready" },
  { name: "Clean", href: "/clean/", description: "Editorial, respira, minimalista", status: "ready" },
  { name: "Acolhedor", href: "/acolhedor/", description: "Quente, humano, acessível", status: "ready" },
  { name: "Moderno", href: "/moderno/", description: "Ousado, diferente, bold", status: "ready" },
  { name: "Institucional", href: "/institucional/", description: "Sólido, confiável, tradicional", status: "ready" },
];
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Templates — Sites para Médicos</title>
</head>
<body style="font-family: system-ui; max-width: 600px; margin: 2rem auto; padding: 0 1rem;">
  <h1>Templates — Sites para Médicos</h1>
  <p style="color: #666;">5 estilos visuais distintos. Clique para visualizar.</p>
  <ul style="list-style: none; padding: 0; margin-top: 2rem;">
    {styles.map((s) => (
      <li style="margin-bottom: 1rem; padding: 1rem; border: 1px solid #ddd; border-radius: 8px;">
        {s.status === "ready" ? (
          <a href={s.href} style="font-size: 1.25rem; font-weight: bold;">{s.name}</a>
        ) : (
          <span style="font-size: 1.25rem; font-weight: bold; color: #999;">{s.name} (em breve)</span>
        )}
        <p style="color: #666; margin: 0.25rem 0 0;">{s.description}</p>
      </li>
    ))}
  </ul>
</body>
</html>
