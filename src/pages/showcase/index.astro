---
import Hero from "../../components/sections/Hero.astro";
import Sobre from "../../components/sections/Sobre.astro";
import Especialidades from "../../components/sections/Especialidades.astro";
import Sinais from "../../components/sections/Sinais.astro";
import Diferenciais from "../../components/sections/Diferenciais.astro";
import ComoFunciona from "../../components/sections/ComoFunciona.astro";
import Depoimentos from "../../components/sections/Depoimentos.astro";
import FAQ from "../../components/sections/FAQ.astro";
import CTAFinal from "../../components/sections/CTAFinal.astro";
import Footer from "../../components/sections/Footer.astro";
import Videos from "../../components/sections/Videos.astro";
import Icon from "../../components/ui/Icon.astro";

import premiumData from "../../data/personas/premium.json";
import cleanData from "../../data/personas/clean.json";
import acolhedorData from "../../data/personas/acolhedor.json";
import modernoData from "../../data/personas/moderno.json";
import institucionalData from "../../data/personas/institucional.json";
import type { Persona } from "../../data/types";

const premium = premiumData as Persona;
const clean = cleanData as Persona;
const acolhedor = acolhedorData as Persona;
const moderno = modernoData as Persona;
const institucional = institucionalData as Persona;

// Sample data for icon showcase
const allIcons = [
  // Cirurgia plástica
  "face", "body", "breast", "aesthetic", "rhinoplasty", "lifting", "lipo", "mammoplasty", "abdominoplasty", "botox",
  // Dermato
  "skincare", "laser", "syringe", "scan", "sun", "skin-clinical", "skin-aesthetic", "hair", "shield-check",
  // Gineco
  "prenatal", "hormones", "contraception", "menopause", "breast-health", "fertility", "obstetrics", "gynecology", "reproductive", "wellness",
  // Odonto
  "implant", "protocol", "immediate-load", "guided-surgery", "bone-graft", "dental-crown", "digital-dentistry", "dental-aesthetics", "dental-surgery",
  // Institucional
  "checkup", "cardiology", "orthopedics", "pediatrics", "endocrinology", "lab", "neurology",
  // Generic
  "heart-handshake", "microscope", "target", "hospital", "clipboard", "clock", "shield", "award", "users", "calendar", "stethoscope", "baby", "leaf",
];
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Showcase — Componentes e Variantes</title>
  <link rel="stylesheet" href="/src/styles/global.css" />
  <style>
    .showcase-section {
      border: 2px dashed #cbd5e1;
      margin: 2rem 0;
      position: relative;
    }
    .showcase-label {
      position: absolute;
      top: -14px;
      left: 24px;
      background: #1e293b;
      color: white;
      font-size: 13px;
      font-weight: 600;
      padding: 2px 12px;
      border-radius: 4px;
      z-index: 10;
      font-family: system-ui;
    }
    .theme-switcher {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #1e293b;
      padding: 12px 24px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }
    .theme-switcher a {
      color: #94a3b8;
      text-decoration: none;
      font-size: 14px;
      font-family: system-ui;
      padding: 4px 12px;
      border-radius: 4px;
      transition: all 0.2s;
    }
    .theme-switcher a:hover {
      color: white;
      background: #334155;
    }
    .section-heading {
      font-family: system-ui;
      font-size: 28px;
      font-weight: 700;
      color: #1e293b;
      padding: 40px 24px 8px;
      margin: 0;
    }
    .section-desc {
      font-family: system-ui;
      font-size: 15px;
      color: #64748b;
      padding: 0 24px 24px;
      margin: 0;
    }
    .icon-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 12px;
      padding: 24px;
    }
    .icon-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 16px 8px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      font-family: system-ui;
      font-size: 11px;
      color: #64748b;
      text-align: center;
    }
    .icon-card svg, .icon-card [data-icon] {
      width: 28px;
      height: 28px;
      color: #1e293b;
    }
  </style>
</head>
<body style="margin:0; background:#f1f5f9;">

  <div class="theme-switcher">
    <span style="color:#94a3b8; font-size:14px; font-family:system-ui; font-weight:600; margin-right:8px;">Showcase</span>
    <a href="#heroes">Heroes</a>
    <a href="#sobre">Sobre</a>
    <a href="#especialidades">Especialidades</a>
    <a href="#sinais">Sinais</a>
    <a href="#diferenciais">Diferenciais</a>
    <a href="#como-funciona">ComoFunciona</a>
    <a href="#depoimentos">Depoimentos</a>
    <a href="#faq">FAQ</a>
    <a href="#cta">CTA Final</a>
    <a href="#footers">Footers</a>
    <a href="#videos">Vídeos</a>
    <a href="#icons">Ícones</a>
    <span style="flex:1"></span>
    <a href="/">← Templates</a>
  </div>

  <!-- ==================== HEROES ==================== -->
  <h2 class="section-heading" id="heroes">Hero</h2>
  <p class="section-desc">4 variantes de layout para a primeira impressão do site.</p>

  <div data-theme="premium">
    <div class="showcase-section">
      <span class="showcase-label">Hero: split — Premium</span>
      <Hero variant="split" hero={premium.sections.hero} photo={premium.doctor.photo} whatsapp={premium.meta.whatsapp} />
    </div>
  </div>

  <div data-theme="moderno">
    <div class="showcase-section">
      <span class="showcase-label">Hero: split-reverse — Moderno</span>
      <Hero variant="split-reverse" hero={moderno.sections.hero} photo={moderno.doctor.photo} whatsapp={moderno.meta.whatsapp} />
    </div>
  </div>

  <div data-theme="clean">
    <div class="showcase-section">
